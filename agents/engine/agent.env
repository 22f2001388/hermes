# Per-agent NON-secret overrides for "engine". Secrets live in repo-root .env or platform secrets — never here. Loaded after root .env, so these win for this agent.

AGENT_PERSONALITY=kawaii

# Fixed host port for local `docker compose` (container always listens on 7860). Registry in README.md.
HOST_PORT=7861

# Telegram API base URL (Cloudflare Worker proxy; HF blocks api.telegram.org directly). Unset = use .hermes/config.yaml default.
TELEGRAM_BASE_URL=https://hermes.22f2001388.workers.dev/bot
