# Hermes environment configuration for systemd
# Copy to /etc/hermes.env and fill in your values, then systemctl enable --now hermes

# ── Required: Gateway authentication token (drives UI + API + WebUI auth) ──
GATEWAY_TOKEN=your-secret-token-here

# ── Required: LLM model specification ───────────────────────────────────────
# Format: provider/model-name
# Examples:
#   openai/gpt-4-turbo
#   openrouter/openai/gpt-4-turbo
#   huggingface/meta-llama/llama-2-70b-chat
#   anthropic/claude-3-sonnet
LLM_MODEL=

# ── Provider API keys (set all needed for your model) ──────────────────────
# Generic fallback (some providers auto-detect from prefix):
LLM_API_KEY=

# Provider-specific (override LLM_API_KEY if set):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
HF_TOKEN=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OLLAMA_API_KEY=

# ── Optional: HuggingFace backup/sync ──────────────────────────────────────
# If set, Hermes state (memories, settings, skills) auto-syncs to HF Spaces
# Leave unset to disable backup
# HF_TOKEN=hf_...

# ── Optional: Telegram bot integration ─────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_ALLOWED_USERS=123456789,987654321
# TELEGRAM_MODE=polling  # or 'webhook' if behind a reverse proxy
# TELEGRAM_WEBHOOK_URL=https://your-vps.com/telegram  # only if webhook mode

# ── Optional: Cloudflare Telegram proxy (for HF/Render fallback) ───────────
# On VPS this is unnecessary, but included for completeness
# CLOUDFLARE_WORKERS_TOKEN=...
# CLOUDFLARE_PROXY_URL=...

# ── Optional: Custom LLM endpoint ──────────────────────────────────────────
# For vLLM, Ollama local, or custom provider:
# CUSTOM_BASE_URL=http://localhost:8000/v1
# CUSTOM_API_KEY=...
# CUSTOM_PROVIDER=ollama
# CUSTOM_MODEL_CONTEXT_LENGTH=131072
# CUSTOM_MODEL_MAX_TOKENS=8192

# ── Agent naming (for multi-agent backup isolation) ───────────────────────
# AGENT_NAME=primary  # default; change if running multiple agents

# ── Sync tuning ────────────────────────────────────────────────────────────
# SYNC_INTERVAL=60  # backup sync interval in seconds (default: 60)
# SYNC_INCLUDE_ENV=1  # include .env in backups (default: 1; set to 0 to exclude)

# ── Supervisor restart limits ──────────────────────────────────────────────
# SUPERVISOR_MAX_RESTARTS=0  # 0=unlimited (default); N=max restarts before exit
# SUPERVISOR_BACKOFF_MAX=30  # max delay between restart attempts (seconds)
# SUPERVISOR_HEALTHY_WINDOW=60  # uptime to reset restart counter (seconds)

# ── WebUI settings ─────────────────────────────────────────────────────────
# HERMES_WEBUI_PASSWORD=  # defaults to GATEWAY_TOKEN if unset
# HERMES_WEBUI_PORT=8787  # default; change if needed

# ── Ports (optional; mostly defaults) ──────────────────────────────────────
# PORT=7861  # public router port (default)
# API_SERVER_PORT=8642  # internal gateway API (default)
# DASHBOARD_PORT=9119  # internal dashboard (default)
# TELEGRAM_WEBHOOK_PORT=8765  # Telegram webhook receiver (default)

# ── HF Spaces specifics (not needed on VPS) ───────────────────────────────
# SPACE_ID=  # auto-detected if HF Space; ignore on VPS
# SPACE_HOST=  # auto-detected if HF Space; ignore on VPS
